<div class="fixed inset-0 pointer-events-none [z-index:2147483647]">
  <div class="absolute w-5 h-5 bg-black/50 dark:bg-white/50 rounded-full" style="transform: translate3d(-100px, -100px, 0);"></div>
</div>

<script>
  const cursor = document.querySelector('.fixed > div') as HTMLElement;
  if (!cursor) throw new Error('Cursor element not found');

  let currentX = -100;
  let currentY = -100;
  let targetX = -100;
  let targetY = -100;
  const ease = 0.25;

  // メインウィンドウのマウス移動イベント
  window.addEventListener('mousemove', (e) => {
    targetX = e.clientX;
    targetY = e.clientY;
  });

  // iframeからのメッセージを受信
  window.addEventListener('message', (event) => {
    // YouTubeドメインからのメッセージのみを受け入れる
    if (event.origin.includes('youtube.com')) {
      const { mouseX, mouseY } = event.data;
      if (mouseX !== undefined && mouseY !== undefined) {
        targetX = mouseX;
        targetY = mouseY;
      }
    }
  });

  function updateCursorPosition() {
    const dx = targetX - currentX;
    const dy = targetY - currentY;

    currentX += dx * ease;
    currentY += dy * ease;

    cursor.style.transform = `translate3d(${currentX - 12.5}px, ${currentY - 12.5}px, 0)`;
    requestAnimationFrame(updateCursorPosition);
  }

  updateCursorPosition();
</script>

<style>
  @media (hover: none) and (pointer: coarse) {
    .fixed > div {
      display: none;
    }
  }
</style>
